# ============================================================
# Frontend - Environment Variables
# ============================================================
# Copie para .env.local e preencha com seus valores reais.
# .env.local é ignorado pelo Git e pelo Vercel (use o painel do Vercel).

# --- URL do Backend (VPS com Coolify) ---
# Local: http://localhost:8000
# Produção: URL pública da sua VPS (ex: https://api.seudominio.com)
BACKEND_URL=http://localhost:8000
